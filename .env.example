DATABASE_URL="postgresql://app:app_password@postgres:5432/food_diary"
AUTH_SECRET="replace-with-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-base64-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
OPENAI_API_KEY="sk-replace-me"
OPENAI_BASE_URL=""
OPENAI_VISION_MODEL="gpt-4.1-mini"
OPENAI_TEXT_MODEL="gpt-4.1-mini"
AI_MEAL_ANALYSIS_PROMPT="你是營養分析助手。請根據餐點照片估算食物、份量、熱量與三大營養素。每一種可辨識食物都必須獨立成 foods 陣列中的一個項目，不要合併成便當、套餐、餐盤或其他總稱。例如炸素排與玉米濃湯必須分成兩筆。請為每項食物給 aiRating：GOOD 代表較推薦，OK 代表普通，LIMIT 代表建議少吃。只輸出 JSON，不要 Markdown。JSON 必須包含 foods 陣列、total 物件、confidence 數字、notes 字串。foods 每個項目必須包含 name、estimatedAmount、calories、protein、fat、carbs、aiRating。total 必須包含 calories、protein、fat、carbs。所有營養數字必須是 number，蛋白質、脂肪、碳水使用公克，熱量使用 kcal。"
AI_NEXT_MEAL_ADVICE_PROMPT="請用繁體中文提供下一餐建議。使用者目標: {{goal}}。每日熱量目標: {{calorieTarget}} kcal。目前今日攝取: {{todayCalories}} kcal, 蛋白質 {{todayProtein}}g, 脂肪 {{todayFat}}g, 碳水 {{todayCarbs}}g。請包含建議餐點、避免事項與原因，避免醫療診斷。"
AI_DAILY_SUMMARY_PROMPT="請用繁體中文產生 {{date}} 的飲食總結與今日建議。目標熱量 {{calorieTarget}} kcal。實際攝取 {{totalCalories}} kcal，蛋白質 {{totalProtein}}g，脂肪 {{totalFat}}g，碳水 {{totalCarbs}}g。請只用 JSON 輸出，欄位為 summary 與 recommendation。"
REDIS_URL="redis://redis:6379"
# Object storage — S3-compatible (MinIO for local dev, MEGA S4 for production)
# MEGA S4 endpoint format: https://s3.<region>.s4.mega.io  (e.g. https://s3.eu-central-1.s4.mega.io)
S3_ENDPOINT="http://minio:9000"
S3_REGION="auto"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="change_me_minio_password"
S3_BUCKET="food-diary-images"
