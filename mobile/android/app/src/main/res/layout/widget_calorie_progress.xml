<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calorie_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_calorie_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/calorie_widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="今日熱量"
            android:textColor="#1C1917"
            android:textSize="13sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:id="@+id/calorie_ring"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:contentDescription="熱量進度環" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/calorie_progress_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="--"
                    android:textColor="#1C1917"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="kcal"
                    android:textColor="#78716C"
                    android:textSize="10sp" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/calorie_consumed_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="-- / ---- kcal"
            android:textColor="#44403C"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calorie_remaining"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="開啟 App 同步"
            android:textColor="#78350F"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calorie_widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="等待今日熱量"
            android:textColor="#A8A29E"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
