<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/summary_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_summary_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/summary_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="昨日 AI 總結"
        android:textColor="#1C1917"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/summary_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="8"
        android:text="昨日總結尚未產生。"
        android:textColor="#44403C"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/summary_recommendation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:background="@drawable/widget_summary_recommendation_background"
        android:ellipsize="end"
        android:maxLines="4"
        android:padding="8dp"
        android:text="開啟 App 查看完整建議"
        android:textColor="#78350F"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/summary_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="不會在桌面即時呼叫 AI"
        android:textColor="#A8A29E"
        android:textSize="10sp" />
</LinearLayout>
