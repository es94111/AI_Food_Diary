<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/water_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_water_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="喝水"
            android:textColor="#0C4A6E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/water_total_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="0 / 2000 ml"
            android:textColor="#1C1917"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/water_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="9dp"
            android:layout_marginTop="4dp"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/water_widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="點一下 +250 ml"
            android:textColor="#0369A1"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/water_add_button"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_water_button_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <ImageView
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:contentDescription="新增喝水"
            android:src="@drawable/ic_widget_water" />

        <TextView
            android:id="@+id/water_percent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="0%"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
