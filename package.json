{
  "name": "ai-food-diary",
  "version": "0.57.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "encryption:rotate": "tsx scripts/rotate-encryption.ts",
    "encryption:backfill:b1": "tsx scripts/backfill-encryption-b1.ts",
    "encryption:backfill:b2": "tsx scripts/backfill-encryption-b2.ts",
    "encryption:migrate:status": "tsx scripts/encryption-migration.ts status",
    "encryption:migrate:verify": "tsx scripts/encryption-migration.ts verify",
    "encryption:migrate:apply": "tsx scripts/encryption-migration.ts apply",
    "encryption:stage-d:status": "tsx scripts/encryption-stage-d.ts status",
    "encryption:stage-d:apply": "tsx scripts/encryption-stage-d.ts apply",
    "encryption:stage-d:rollback": "tsx scripts/encryption-stage-d.ts rollback",
    "encryption:disk:check": "tsx scripts/disk-encryption-check.ts",
    "encryption:images": "tsx --conditions=react-server scripts/backfill-image-encryption.ts",
    "worker": "tsx --conditions=react-server src/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "next": "^16.2.9",
    "openai": "^6.45.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@hono/node-server": "^1.19.13",
    "esbuild": "^0.28.1"
  }
}
