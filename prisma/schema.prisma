generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Goal {
  LOSE_FAT
  MAINTAIN
  BUILD_MUSCLE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  googleId     String?        @unique
  isAdmin      Boolean        @default(false)
  // Bumped to invalidate all outstanding JWTs for this user (logout / future
  // password change). Tokens embed this value as `tv` and are rejected on mismatch.
  tokenVersion Int            @default(0)
  profile      UserProfile?
  meals        Meal[]
  waterLogs    WaterLog[]
  summaries    DailySummary[]
  savedFoods   SavedFood[]
  recommendations DailyRecommendation[]
  healthConnections HealthConnection[]
  healthMetrics HealthMetric[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AppConfig {
  id               String  @id @default("singleton")
  registrationOpen Boolean @default(true)
}

model UserProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  // Legacy plaintext columns. Kept nullable for backward-compatible migration;
  // new writes go to the enc* columns and these are cleared. Removed in a later step.
  gender               String?
  birthDate            DateTime?
  heightCm             Int?
  weightKg             Decimal? @db.Decimal(5, 2)
  // Encrypted (AES-256-GCM) counterparts of the body fields above.
  encGender            Json?
  encBirthDate         Json?
  encHeightCm          Json?
  encWeightKg          Json?
  activityLevel        String?
  goal                 Goal     @default(MAINTAIN)
  calorieTarget        Int      @default(2000)
  waterGoalMl          Int      @default(2000)
  timezone             String?
  encryptedPreferences Json?
  encryptedAllergies   Json?
  // Per-user AI provider config (BYO key). Key is stored encrypted at rest.
  aiProvider           String?  // "openai" | "gemini" | "compatible"
  aiBaseUrl            String?  // only used for "compatible"; others use provider defaults
  aiVisionModel        String?
  aiTextModel          String?
  encryptedAiApiKey    Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Meal {
  id              String     @id @default(cuid())
  userId          String
  mealType        MealType
  imageStorageKey String?
  totalCalories   Decimal    @default(0) @db.Decimal(8, 2)
  totalProtein    Decimal    @default(0) @db.Decimal(8, 2)
  totalFat        Decimal    @default(0) @db.Decimal(8, 2)
  totalCarbs      Decimal    @default(0) @db.Decimal(8, 2)
  aiConfidence    Decimal?   @db.Decimal(4, 3)
  // Legacy plaintext AI notes. Kept nullable while B2 rows are backfilled.
  aiNotes         String?
  encAiNotes      Json?
  aiRawEncrypted  Json?
  items           MealItem[]
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eatenAt         DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId, eatenAt])
}

model MealItem {
  id              String   @id @default(cuid())
  mealId          String
  // Legacy plaintext columns. Kept nullable while B2 rows are backfilled.
  name            String?
  estimatedAmount String?
  encName         Json?
  encEstimatedAmount Json?
  calories        Decimal  @default(0) @db.Decimal(8, 2)
  protein         Decimal  @default(0) @db.Decimal(8, 2)
  fat             Decimal  @default(0) @db.Decimal(8, 2)
  carbs           Decimal  @default(0) @db.Decimal(8, 2)
  aiRating        String   @default("MANUAL")
  meal            Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amountMl  Int
  drankAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, drankAt])
}

model SavedFood {
  id              String   @id @default(cuid())
  userId          String
  barcode         String?
  // Legacy plaintext columns. Kept nullable while B2 rows are backfilled.
  name            String?
  estimatedAmount String?
  encName         Json?
  encEstimatedAmount Json?
  calories        Decimal  @default(0) @db.Decimal(8, 2)
  protein         Decimal  @default(0) @db.Decimal(8, 2)
  fat             Decimal  @default(0) @db.Decimal(8, 2)
  carbs           Decimal  @default(0) @db.Decimal(8, 2)
  source          String   @default("MANUAL")
  isFavorite      Boolean  @default(false)
  useCount        Int      @default(0)
  lastUsedAt      DateTime?
  archivedAt      DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, name])
  @@index([userId, archivedAt, isFavorite, lastUsedAt])
  @@unique([userId, barcode])
}

model DailySummary {
  id               String   @id @default(cuid())
  userId           String
  summaryDate      DateTime
  totalCalories    Decimal  @default(0) @db.Decimal(8, 2)
  totalProtein     Decimal  @default(0) @db.Decimal(8, 2)
  totalFat         Decimal  @default(0) @db.Decimal(8, 2)
  totalCarbs       Decimal  @default(0) @db.Decimal(8, 2)
  // Legacy plaintext columns. Kept nullable while B2 rows are backfilled.
  aiSummary        String?
  aiRecommendation String?
  encAiSummary     Json?
  encAiRecommendation Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, summaryDate])
}

model DailyRecommendation {
  id             String   @id @default(cuid())
  userId         String
  recommendationDate DateTime
  advice         String
  totalCalories  Decimal  @default(0) @db.Decimal(8, 2)
  totalProtein   Decimal  @default(0) @db.Decimal(8, 2)
  totalFat       Decimal  @default(0) @db.Decimal(8, 2)
  totalCarbs     Decimal  @default(0) @db.Decimal(8, 2)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, recommendationDate])
}

model HealthMetric {
  id         String   @id @default(cuid())
  userId     String
  source     String
  type       String
  // Legacy plaintext value; nullable during migration. New writes use encValue
  // and leave this null. type/unit/measuredAt stay plaintext (needed for the
  // unique key and for filtering/queries).
  value      Float?
  unit       String
  measuredAt DateTime
  rawEncrypted Json?
  encValue   Json?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, source, type, measuredAt])
  @@index([userId, measuredAt])
  @@index([userId, type, measuredAt])
}

model HealthConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("HEALTH_CONNECT")
  deviceName   String?
  tokenHash    String   @unique
  lastSyncedAt DateTime?
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, revokedAt])
}
